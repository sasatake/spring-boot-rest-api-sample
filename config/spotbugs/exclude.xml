<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
		xmlns="https://github.com/spotbugs/filter/3.0.0"
		xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

	<!-- model / dto は Jackson・MyBatis と受け渡しする薄いデータホルダーであり、
	     コレクションの防御的コピーは行わない方針のため、内部表現の露出は許容する -->
	<Match>
		<Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
	</Match>

	<!-- テストヘルパーの jdbcTemplate.queryForObject 戻り値は、null ならテストが
	     即座に例外で失敗して気づけるため、null チェックを省略している -->
	<Match>
		<Class name="~.*Test"/>
		<Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
	</Match>
</FindBugsFilter>
